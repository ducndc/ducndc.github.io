---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Chung Duc Nguyen Dang</h1>
			<p class="subtitle">
			I am a Computer Engineer, 
			an enthusiast of the photography, and a writer of poetry.
			</p>
			<div class="cta-buttons">
			<a href="/about" class="btn primary">About Me</a>
			<a href="/blog" class="btn secondary">Read My Blog</a>
			</div>
		</section>

		<section class="grid-sections">
		<div class="card">
		<h3>💻 Engineering</h3>
		<p>Specializing in Wi-Fi drivers, firmware, and next-gen transport networking at VHT.</p>
		</div>

		<div class="card">
		<h3>🔌 Electronics</h3>
		<p>Building the physical world through IoT systems, UAV development, and embedded hardware.</p>
		</div>
		
		<div class="card">
		<h3>📷 Photography</h3>
		<p>Capturing the world through the glass of my Canon 60D and the streets of Hanoi.</p>
		</div>

		<div class="card">
		<h3>✍️ Poetry</h3>
		<p>Finding the rhythm in the code and the melody in the quiet moments of the everyday.</p>
		</div>

		</main>
		<Footer />
	</body>
</html>

<style>
  .hero {
    padding: 4rem 0;
    text-align: center;
    background: linear-gradient(to right, #f8f9fa, #e9ecef);
    border-radius: 12px;
    margin-bottom: 3rem;
  }
  h1 { font-size: 2.5rem; color: #333; }
  .subtitle { font-size: 1.25rem; color: #666; max-width: 600px; margin: 1rem auto; }
  
  .grid-sections {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }
  
  .card {
    padding: 1.5rem;
    border: 1px solid #eee;
    border-radius: 8px;
    transition: transform 0.2s;
  }
  .card:hover { transform: translateY(-5px); border-color: #007acc; }
  
  .btn {
    padding: 0.8rem 1.5rem;
    border-radius: 5px;
    text-decoration: none;
    font-weight: bold;
    margin: 0.5rem;
    display: inline-block;
  }
  .primary { background: #007acc; color: white; }
  .secondary { border: 1px solid #007acc; color: #007acc; }
</style>